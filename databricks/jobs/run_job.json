{
  "name": "tesco-mlops-training-pipeline",
  "description": "End-to-end customer segmentation and propensity modelling pipeline",
  "email_notifications": {
    "on_failure": ["ml-platform-alerts@tesco.com"],
    "on_success": [],
    "no_alert_for_skipped_runs": true
  },
  "timeout_seconds": 7200,
  "max_concurrent_runs": 1,
  "tags": {
    "project": "tesco-mlops",
    "team": "ml-platform"
  },
  "tasks": [
    {
      "task_key": "ingest",
      "description": "Stream transactions from Event Hub to ADLS bronze layer",
      "notebook_task": {
        "notebook_path": "/Shared/tesco-mlops/01_ingest",
        "source": "WORKSPACE"
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true"
        }
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 60000
    },
    {
      "task_key": "feature_engineering",
      "description": "Build RFM and behavioural features into silver layer",
      "depends_on": [{"task_key": "ingest"}],
      "notebook_task": {
        "notebook_path": "/Shared/tesco-mlops/02_feature_engineering",
        "source": "WORKSPACE"
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS4_v2",
        "num_workers": 4,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true"
        }
      },
      "timeout_seconds": 3600,
      "max_retries": 1
    },
    {
      "task_key": "train_segmentation",
      "description": "Train KMeans segmentation model and log to MLflow",
      "depends_on": [{"task_key": "feature_engineering"}],
      "notebook_task": {
        "notebook_path": "/Shared/tesco-mlops/03_train_segmentation",
        "source": "WORKSPACE",
        "base_parameters": {
          "n_clusters": "5"
        }
      },
      "new_cluster": {
        "spark_version": "14.3.x-ml-scala2.12",
        "node_type_id": "Standard_DS4_v2",
        "num_workers": 2
      },
      "timeout_seconds": 3600,
      "max_retries": 1
    },
    {
      "task_key": "train_propensity",
      "description": "Train LightGBM propensity model per target category",
      "depends_on": [{"task_key": "train_segmentation"}],
      "notebook_task": {
        "notebook_path": "/Shared/tesco-mlops/04_propensity_model",
        "source": "WORKSPACE",
        "base_parameters": {
          "target_category": "ready_meals"
        }
      },
      "new_cluster": {
        "spark_version": "14.3.x-ml-scala2.12",
        "node_type_id": "Standard_DS4_v2",
        "num_workers": 4
      },
      "timeout_seconds": 3600,
      "max_retries": 1
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 2 * * ?",
    "timezone_id": "Europe/London",
    "pause_status": "UNPAUSED"
  },
  "git_source": {
    "git_url": "https://github.com/tesco/tesco-mlops-azure",
    "git_provider": "gitHub",
    "git_branch": "main"
  }
}
